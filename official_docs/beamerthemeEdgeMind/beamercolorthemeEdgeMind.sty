\setbeamercovered{transparent}

% Bullets and section name in the slides
\setbeamercolor*{structure}{fg=EMLogoOrange}


\setbeamercolor*{footline}{fg=EMLogoBlue,bg=EMGrey}

% Text noraml
\setbeamercolor{normal text}{fg=black}

% Title
\setbeamercolor{title}{fg=EMGrey, bg=EMLogoBlue}
% Author, Date etc
\setbeamercolor{title page}{fg=EMLogoOrange}

% Frame title
\setbeamercolor{palette primary}{fg=EMGrey, bg=EMLogoBlue}


% Blocks
% ------
% Normal
\setbeamercolor{block title}{fg=White,bg=EMLogoOrange}

% Example
\setbeamercolor{example text}{fg=EMLogoBlue}
\setbeamercolor{block title example}{use=example text,fg=White,bg=EMLogoBlue}

% Alerted
\setbeamercolor{alerted text}{fg=EMRed}
\setbeamercolor{block title alerted}{use=alerted text,fg=White,bg=EMRed}


\setbeamercolor*{separation line}{}
\setbeamercolor*{fine separation line}{}

